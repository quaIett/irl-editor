# --- volumetric upsample (after pow 2.2, linear) + rim outline (before pow 2.2, gamma) ---
@file shaders/program/composite1.glsl
after "#include \"/lib/util/spaceConversion.glsl\""
<<<
#include "/lib/irlite/irlite_lights.glsl"
>>>
before "    color = pow(color, vec3(2.2));"
<<<
    #if defined IRLITE_ACTIVE && defined IRLITE_OUTLINE
        // IRLite backlight rim outline; post-translucent, before pow-2.2. IRLITE_OUTLINE_TARGET gates by gbuffer materialMask: entities = PBR 100..199 or default 254, blocks = 0..99.
        bool irliteODraw = z0 < 1.0 && z0 > 0.56;
        #if IRLITE_OUTLINE_TARGET != 0
            if (irliteODraw) {
                float irliteOMat = texelFetch(colortex6, texelCoord, 0).g * 255.0;
                bool irliteOEntity = (irliteOMat > 99.5 && irliteOMat < 199.5) || irliteOMat > 253.5;
                #if IRLITE_OUTLINE_TARGET == 1
                    irliteODraw = irliteOEntity;   // only entities
                #else
                    irliteODraw = !irliteOEntity;  // only blocks
                #endif
            }
        #endif
        if (irliteODraw) {
            vec3 irliteOPlayerPos = ViewToPlayer(viewPos.xyz);
            vec3 irliteDerivN = cross(dFdx(irliteOPlayerPos), dFdy(irliteOPlayerPos));
            #ifdef PBR_REFLECTIONS
                vec3 irliteFlatN = texelFetch(colortex4, texelCoord, 0).rgb;
                if (dot(irliteFlatN, irliteFlatN) < 1e-4) irliteFlatN = irliteDerivN;
            #else
                vec3 irliteFlatN = irliteDerivN;
            #endif
            if (dot(irliteFlatN, irliteOPlayerPos) > 0.0) irliteFlatN = -irliteFlatN;
            color += IRLITE_INTENSITY * irlite_outlineInk(irliteOPlayerPos, irliteFlatN);
        }
    #endif

>>>
after "    color = pow(color, vec3(2.2));"
<<<

    #if defined IRLITE_ACTIVE && defined IRLITE_VOLUMETRIC
        // IRLite VL: reduced-res deferred2 -> colortex10, upsampled here in LINEAR space.
        // vlC.w bit6 = depth-aware bilateral: 4 low-res texel centers, bilinear weight x
        // view-depth weight against depthtex1 (deferred2 marched the opaque depth) - kills
        // halos/staircase on silhouettes at RESOLUTION < 1. The +0.25 fetch bias steps off
        // the exact pixel corner the texel-center uv lands on at half/quarter res (float
        // rounding would flip the picked pixel per column); at full res floor(t+0.75) = t.
        // Depth metric = true view-space Z in blocks, nf/(f - z(f-n)): the pack's
        // GetLinearDepth*far is 2df/(d+f), which would stretch sigma 0.5x-2x over distance.
        vec3 irliteVL;
        if ((irlite_vlC.w & 64u) != 0u) {
            ivec2 irliteVlSize = textureSize(colortex10, 0);
            vec2 irliteVlPos = texCoord * vec2(irliteVlSize) - 0.5;
            vec2 irliteVlBase = floor(irliteVlPos);
            vec2 irliteVlFrac = irliteVlPos - irliteVlBase;
            float irliteRefDepth = (near * far) / (far - z1 * (far - near));
            float irliteSigma = irlite_vlD.y > 0.0 ? irlite_vlD.y : 1.5; // blocks (vlD.y 0 = default)
            vec3 irliteVlSum = vec3(0.0);
            float irliteVlWSum = 0.0;
            for (int i = 0; i < 4; i++) {
                ivec2 irliteTap = ivec2(i & 1, i >> 1);
                ivec2 irliteTexel = clamp(ivec2(irliteVlBase) + irliteTap, ivec2(0), irliteVlSize - 1);
                vec2 irliteTapUv = (vec2(irliteTexel) + 0.5) / vec2(irliteVlSize);
                float irliteTapZ = texelFetch(depthtex1, ivec2(irliteTapUv * view + 0.25), 0).r;
                float irliteTapLin = (near * far) / (far - irliteTapZ * (far - near));
                float irliteDz = abs(irliteTapLin - irliteRefDepth) / irliteSigma;
                vec2 irliteBi = mix(1.0 - irliteVlFrac, irliteVlFrac, vec2(irliteTap));
                float irliteW = irliteBi.x * irliteBi.y / (1.0 + irliteDz * irliteDz);
                irliteVlSum += texelFetch(colortex10, irliteTexel, 0).rgb * irliteW;
                irliteVlWSum += irliteW;
            }
            // Sub-tap geometry (fences/leaves): no tap depth matches -> plain bilinear beats
            // a normalized mush of 4 wrong-surface taps.
            irliteVL = irliteVlWSum > 1e-3 ? irliteVlSum / irliteVlWSum : texture2D(colortex10, texCoord).rgb;
        } else {
            irliteVL = texture2D(colortex10, texCoord).rgb;
        }
        if (isEyeInWater == 1) {
            vec3 irliteUWM = vec3(0.80, 0.87, 0.97) * 0.55;
            irliteVL *= irliteUWM * irliteUWM;
        } else if (isEyeInWater == 2) {
            irliteVL = vec3(0.0);
        }
        color += irliteVL;
    #endif
>>>

